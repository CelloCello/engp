            ["leave", "離開", "left"],
            ["meet", "遇見", "met"]
          ]
        },
        {
          "type": "table",
          "title": "規則動詞的過去式",
          "columns": ["原形", "中文", "過去式"],
          "rows": [
            ["play", "玩", "played"],
            ["look", "看", "looked"],
            ["walk", "走路", "walked"],
            ["help", "幫助", "helped"],
            ["talk", "講話", "talked"],
            ["jump", "跳", "jumped"],
            ["wash", "洗", "washed"],
            ["clean", "清理", "cleaned"],
            ["open", "打開", "opened"],
            ["close", "關上", "closed"],
            ["call", "打電話、叫", "called"],
            ["want", "想要", "wanted"],
            ["need", "需要", "needed"],
            ["like", "喜歡", "liked"],
            ["love", "愛、喜歡", "loved"],
            ["live", "住", "lived"],
            ["move", "移動", "moved"],
