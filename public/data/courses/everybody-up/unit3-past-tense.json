            ["think", "想", "thought"],
            ["run", "跑", "ran"],
            ["sit", "坐", "sat"],
            ["stand", "站", "stood"],
            ["read", "閱讀", "read"],
            ["write", "寫", "wrote"],
            ["speak", "說話", "spoke"],
            ["tell", "告訴", "told"],
